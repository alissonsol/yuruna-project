# Yuruna project line-ending policy. Mirrors yuruna/.gitattributes.
#
# A Yuruna host clones this repo into <yuruna-repo-root>/project/ each
# cycle and serves files byte-faithfully over HTTP to the Linux guest
# VMs under test. If a developer's git is configured with
# core.autocrlf=true (the Windows default after some "Git for Windows"
# installers), `*.sh` files are checked out as CRLF, the status server
# serves CRLF bytes, and the guest's bash chokes with `$'\r': command
# not found` (or, worse, a mangled `set: pipefail\r: invalid option
# name` from `set -euo pipefail`) on the very first script line. This
# file forces LF on every text type a Linux guest reads, regardless of
# any per-developer config.

# Files consumed by Linux guests -- must always be LF.
# `user-data` and `meta-data` are cloud-init seed names without an
# extension; the bare-name patterns match them in any directory.
*.sh         text eol=lf
*.bash       text eol=lf
*.yml        text eol=lf
*.yaml       text eol=lf
*.service    text eol=lf
*.conf       text eol=lf
*.toml       text eol=lf
user-data    text eol=lf
meta-data    text eol=lf
Dockerfile   text eol=lf

# PowerShell scripts run on both Windows and macOS hosts. pwsh handles
# either EOL, but LF keeps the repo consistent and avoids round-trip
# CRLF<->LF churn when a file is edited on macOS, committed, then re-
# checked-out on Windows.
*.ps1        text eol=lf
*.psm1       text eol=lf

# Windows-only text formats -- must be CRLF.
*.bat        text eol=crlf
*.cmd        text eol=crlf
*.ps1xml     text eol=crlf

# Repo metadata / docs -- LF is fine on every editor we ship for.
*.md         text eol=lf
*.json       text eol=lf
*.jsonc      text eol=lf
*.txt        text eol=lf
*.html       text eol=lf
*.css        text eol=lf
*.cshtml     text eol=lf
*.cshtml.css text eol=lf
*.js         text eol=lf

# Binaries -- never normalize.
*.png        binary
*.jpg        binary
*.jpeg       binary
*.gif        binary
*.ico        binary
*.pfx        binary
*.zip        binary
*.7z         binary
*.tar        binary
*.tar.gz     binary
*.tgz        binary
*.exe        binary
*.dll        binary
