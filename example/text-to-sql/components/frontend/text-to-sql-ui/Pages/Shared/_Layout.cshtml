<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — Agentic Text-to-SQL</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <header class="page-header">
      <div class="brand">
        <span class="brand-title">Agentic Text-to-SQL</span>
        <span class="brand-sub">Yuruna example</span>
      </div>
      <nav class="top-nav">
        <a asp-page="/Index">Ask</a>
        <a asp-page="/Schema">Schema</a>
        <a asp-page="/About">About</a>
      </nav>
    </header>
    <main class="container">
        @RenderBody()
    </main>
    <footer class="page-footer">
      © 2026 Alisson Sol · Read-only agent · PostgreSQL backend ·
      <a href="https://github.com/alissonsol/yuruna" target="_blank">Yuruna</a>
    </footer>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
